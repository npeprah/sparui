# Backend API Configuration
VITE_BACKEND_URL=http://localhost:8080

# Environment (development, staging, production)
VITE_ENV=development

# Feature Flags
VITE_ENABLE_DEBUG=true
VITE_ENABLE_MOCK_DATA=false

# Analytics (optional)
VITE_ANALYTICS_ID=

# Game Configuration
VITE_DEFAULT_TIMEOUT=15
VITE_MAX_PLAYERS=4
